{
  "firestore": {
    "database": "(default)",
    "location": "asia-southeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/index",
        "destination": "/index.html"
      },
      {
        "source": "/browse",
        "destination": "/browse.html"
      },
      {
        "source": "/book",
        "destination": "/book.html"
      },
      {
        "source": "/profile",
        "destination": "/profile.html"
      },
      {
        "source": "/about-alliance",
        "destination": "/about-alliance.html"
      },
      {
        "source": "/pp",
        "destination": "/pp.html"
      },
      {
        "source": "/tos",
        "destination": "/tos.html"
      },
      {
        "source": "/upload",
        "destination": "/upload.html"
      }
    ]
  }
}